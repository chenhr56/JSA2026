%AXGBeginBitmap: java.awt.image.BufferedImage
{{
/RawData currentfile /ASCII85Decode filter def
/Data RawData /FlateDecode filter def
/DeviceRGB setcolorspace
<<
  /ImageType 1
  /Decode [0 1 0 1 0 1]
  /DataSource Data
  /Height 225
  /ImageMatrix [450 0 0 225 0 0]
  /Width 450
  /BitsPerComponent 8
>> image
} stopped {handleerror} if
  RawData flushfile
} exec
