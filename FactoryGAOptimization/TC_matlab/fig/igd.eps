[0.47985 0 0 0.48 0 108.00001] CT
[1 0 0 1 0 0] CT
N
0 -225 M
1563 -225 L
1563 400 L
0 400 L
0 -225 L
cp
clip
GS
0 0 translate
1000 400 scale
%AXGBeginBitmap: java.awt.image.BufferedImage
{{
/RawData currentfile /ASCII85Decode filter def
/Data RawData /FlateDecode filter def
/DeviceRGB setcolorspace
<<
  /ImageType 1
  /Decode [0 1 0 1 0 1]
  /DataSource Data
  /Height 400
  /ImageMatrix [1000 0 0 400 0 0]
  /Width 1000
  /BitsPerComponent 8
>> image
} stopped {handleerror} if
  RawData flushfile
} exec
