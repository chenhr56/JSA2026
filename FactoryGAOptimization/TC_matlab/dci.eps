%%Page: 1 1
%%PageBoundingBox: 0 0 600 300
%%BeginPageSetup
[1 0 0 -1 0 300] CT
%%EndPageSetup
GS
[0.75 0 0 0.75 0 0] CT
1 GC
N
0 0 800 400 re
f
GR
GS
[0.48 0 0 0.48 0 108.00001] CT
[1 0 0 1 0 0] CT
N
0 -225 M
1250 -225 L
1250 400 L
0 400 L
0 -225 L
cp
clip
GS
0 0 translate
800 400 scale
%AXGBeginBitmap: java.awt.image.BufferedImage
{{
/RawData currentfile /ASCII85Decode filter def
/Data RawData /FlateDecode filter def
/DeviceRGB setcolorspace
<<
  /ImageType 1
  /Decode [0 1 0 1 0 1]
  /DataSource Data
  /Height 400
  /ImageMatrix [800 0 0 400 0 0]
  /Width 800
  /BitsPerComponent 8
>> image
} stopped {handleerror} if
  RawData flushfile
} exec
